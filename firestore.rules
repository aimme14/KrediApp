rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Super Admin: fuera de empresas
    match /superAdmin/{adminID} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Índice de auth para usuarios de empresas (jefe, admin, empleado).
    // Leer: propio doc, o superAdmin lee todos, o el doc fue creado por ti (jefe ve sus admins, admin ve sus empleados).
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
            || (exists(/databases/$(database)/documents/superAdmin/$(request.auth.uid))
                && get(/databases/$(database)/documents/superAdmin/$(request.auth.uid)).data.role == 'superAdmin')
            || resource.data.createdBy == request.auth.uid);
      allow write: if false;
    }
    // Empresas y todas sus subcolecciones
    match /empresas/{empresaId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /usuarios/{usuarioId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      match /rutas/{rutaId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      match /clientes/{clienteId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      match /prestamos/{prestamoId} {
        allow read: if request.auth != null;
        allow write: if false;
        match /pagos/{pagoId} {
          allow read: if request.auth != null;
          allow write: if false;
        }
      }
      match /gastos/{gastoId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
